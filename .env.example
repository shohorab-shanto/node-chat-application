# Application Configuration

# Server Port
PORT=5000

# MongoDB Connection String
# Examples:
# Local: mongodb://localhost:27017/chat-app
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_CONNECTION_STRING=mongodb://localhost:27017/chat-app

# Cookie Secret Key (Use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your-super-secret-cookie-key-here

# Application Name (displayed in UI)
APP_NAME=Chat Application

# Node Environment (automatically set by npm scripts)
# development or production
NODE_ENV=development
